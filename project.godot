; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LocalPoker"
config/description="Texas Hold'em MVP — local heads-up, console debug"
run/main_scene="res://scenes/lobby.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Net="*res://scripts/network_manager.gd"
NetGame="*res://scripts/network_game_controller.gd"

[debug]

gdscript/warnings/untyped_declaration=1

[rendering]

renderer/rendering_method="forward_plus"
